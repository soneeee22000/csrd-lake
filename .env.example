# ─────────────────────────────────────────────────────────────────────
# CSRD-Lake — Environment Variables
# Copy to .env and fill in values. NEVER commit .env (it's gitignored).
# ─────────────────────────────────────────────────────────────────────

# ── LLM APIs ─────────────────────────────────────────────────────────
# Anthropic Claude — primary extraction LLM
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Mistral — fallback extraction LLM (FR-language edge cases, cost optimization)
# Get key: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ── Snowflake (free trial: https://signup.snowflake.com/) ────────────
SNOWFLAKE_ACCOUNT=               # e.g. abc12345.eu-west-1.aws
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CSRD_LAKE
SNOWFLAKE_SCHEMA=RAW

# ── Airflow (Docker Compose local) ───────────────────────────────────
# AIRFLOW_UID is your host UID for shared volume permissions
# Find with: id -u
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=        # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=   # Generate: openssl rand -hex 16
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── dbt ──────────────────────────────────────────────────────────────
# dbt picks up Snowflake creds from the SNOWFLAKE_* vars above
# via dbt_project/profiles.yml.
DBT_PROFILES_DIR=./dbt_project
DBT_TARGET=dev

# ── Pipeline behavior ────────────────────────────────────────────────
# Confidence threshold for routing to human review queue
CONFIDENCE_THRESHOLD=0.80

# Max pages to read per sustainability PDF (perf cap)
MAX_PDF_PAGES=200

# Languages to attempt extraction in (v1: FR + EN)
EXTRACTION_LANGUAGES=fr,en

# Number of LLM retries on malformed output
LLM_MAX_RETRIES=3

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json   # 'json' for production, 'console' for dev readability
